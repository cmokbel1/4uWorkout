{
  "expo": {
    "name": "4UWorkout Trainer",
    "slug": "4uworkout-trainer",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/4uWorkout-icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.claudemokbel.workout-trainer4u",
      "icon": "./assets/4uWorkout-icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/4uicon.png",
        "backgroundColor": "#0D1B2A"
      },
      "package": "com.claudemokbel.workout_trainer4u",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "ddbb0178-db31-4192-8bf7-a32b80388764"
      }
    },
    "plugins": [
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "targetSdkVersion": 35,
            "compileSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ]
  }
}
